# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (used by base/prod settings; dev defaults to SQLite)
DB_NAME=hrm_db
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/1

# Email (Google Workspace SMTP relay)
# Set EMAIL_BACKEND to console backend in dev if desired:
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp-relay.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False

# Leave empty for IP-allowlist relay policies; set for SMTP-auth relay policies.
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Sender identity
DEFAULT_FROM_EMAIL=hrms@incelgroup.com

# Used to generate deep links in emails (e.g. /leave/requests/<id>)
FRONTEND_BASE_URL=http://localhost:3000

# Pagination
PAGE_SIZE=20
